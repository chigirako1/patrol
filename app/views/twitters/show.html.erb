
<% title = twitter_show_page_title(@twitter) %>
<% provide(:title, title) %>
<p style="color: green"><%= notice %></p>

<h1>
    <%= twitter_show_header_str(@twitter) %>
</h1>

<% if @twitter.status.presence and @twitter.status != Twitter::TWT_STATUS::STATUS_PATROL %>
    <h3><%= @twitter.status %></h3>
<% end %>

<%= render @twitter %>
<hr />

<% if params[:seq_chk] == "true" %>
  <%= render "list", twitter: @twitter %>
  <hr />
<% elsif params[:viewer] == "true" %>
  <%= render "viewer", twitter: @twitter %>
  <hr />
<% else %>
  <%= render "twt_pic_list", twitter: @twitter %>
  <hr />

  <%= render "form", twitter: @twitter %>
  <hr />
<% end %>

<div class="view_form">
  <h2>検索</h2>
  <%= form_with(url: twitter_path, local: true, method: :get) do |f| %>
    検索tweet id/url/日付:<%= f.text_field :search_id, :value => params[:search_id] %>
    <%= f.submit("検索", name: nil, class: 'submit-btn') %>
    <%#= f.hidden_field :picn, value: 'all' %>
    <br />

  <% end %>
</div>

