<div id="<%= dom_id tweet %>">
    <p>
        <% if tweet.status != Tweet::StatusEnum::SAVED %>
            <h4><%= tweet.status %></h4>
        <% end %>
        <strong>Tweet ID:</strong>
        <%= tweet.tweet_id %>
        <strong>スクリーンネーム:</strong>
        <%= tweet.screen_name %>
        <strong>評価:</strong>
        <%= tweet.rating %>
        <strong>枚数:</strong>
        <%= tweet.num %>
        <strong>備考:</strong>
        <%= tweet.remarks %>
    </p>

    <% twt = Twitter.find_by(twtid: tweet.screen_name) %>
    <% if twt %>
        <%#= twitter_info_tag(twt) %>
    <% elsif tweet.screen_name.presence %>
    <% end %>
    [<%= link_to_ex %!☆twt☆:@#{tweet.screen_name}!, artist_twt_path(tweet.screen_name, picn: 33) %>]
    [<%= link_to_ex("tweets db", tweets_path(screen_name: tweet.screen_name)) %>]
    <br />

    <% if @pic_list %>
        <%= @pic_list.size %>枚<br />

        <% (@pic_list||[]).each do |path| %>
            <% if path.include? tweet.tweet_id.to_s %>
                <%= image_link(path) %>
            <% else %>
            <% end %>
        <% end %>

        <% if tweet.remarks.presence %>
            <% (@pic_list||[]).each do |path| %>
                <% if path.include? tweet.remarks %>
                    <%= image_link(path) %>
                <% else %>
                <% end %>
            <% end %>

            <% filelist2 = Twt::get_sp_pic_filelist2_by_twtid(tweet.screen_name) %>
            <% filelist2.each do |path| %>
                <% if path.include? tweet.remarks %>
                    <%= image_link(path) %>
                <% else %>
                <% end %>
            <% end %>
        <% end %>
    <% end %>

    <%= link_to_ex("▶x", Twt::twt_tweet_url_i(tweet.tweet_id)) %><br />
</div>
