<%= form_with(model: tweet) do |form| %>
    <% if tweet.errors.any? %>
        <div style="color: red">
        <h2><%= pluralize(tweet.errors.count, "error") %> prohibited this tweet from being saved:</h2>

        <ul>
            <% tweet.errors.each do |error| %>
                <li><%= error.full_message %></li>
            <% end %>
        </ul>
        </div>
    <% end %>

    <div>
        <%= form.label :tweet_id, style: "display: block" %>

        <% if tweet.tweet_id.presence %>
            <% tweet_id_val = tweet.tweet_id %>
        <% elsif params[:tweet_id].presence %>
            <% tweet_id_val = params[:tweet_id] %>
        <% else %>
            <% tweet_id_val = "" %>
        <% end %>
        <%= form.number_field :tweet_id, value: tweet_id_val %>

        <%= link_to_ex("▶x(#{tweet_id_val})", Twt::twt_tweet_url_i(tweet_id_val)) %>

        <% if tweet.tweet_id.presence %>
            <% time = Twt::get_timestamp(tweet.tweet_id) %>

            <% twt = Twitter.find_by_twtid_ignore_case(tweet.screen_name) %>
            <% if twt %>
                <% if twt.oldest_tweet_id and twt.oldest_tweet_id > tweet.tweet_id %>
                    <h4>
                    [<%= smart_date time %>(<%= Util::get_date_info time %>)]
                    最古のIDより古いツイート(新:<%= twt.oldest_tweet_id %> > 古:<%= tweet.tweet_id %>[これ])
                    </h4>
                <% elsif twt.last_access_datetime > time %>
                    <h4>
                    [<%= link_to_ex(%!☆twt☆:@#{smart_date(time.to_date)}!, artist_twt_path(tweet.screen_name, sdate: time.to_date, nl: false)) %>]
                    最後のアクセス(<%= smart_date twt.last_access_datetime %>)
                    より前のツイート(<%= smart_date time %>)
                    </h4>
                <% else %>
                    <%= smart_date time %>[<%= Util::get_date_info time %>]
                <% end %>
            <% else %>
                <%= smart_date time %>[<%= Util::get_date_info time %>]
            <% end %>
        <% end %>
    </div>

    <div>
        <%= form.label :screen_name, style: "display: block" %>

        <% if tweet.screen_name.presence %>
            <% screen_name_val = tweet.screen_name %>
        <% elsif params[:screen_name].presence %>
            <% screen_name_val = params[:screen_name] %>
        <% else %>
            <% screen_name_val = "" %>
        <% end %>

        <%= form.text_field :screen_name, value: screen_name_val, autofocus: true %>

        <%= twitter_info_tag_ex(tweet.screen_name, true, true) %>
        <% if tweet.screen_name.presence %>
            <h3>
                <%= link_to_ex("▶@" + tweet.screen_name, Twt::twt_user_media_url(tweet.screen_name)) %>
            </h3>
        <% end %>
    </div>

    <div>
        <% val = get_val(tweet.status, :status) %>
        <%= form.label :status, style: "display: block" %>
        <%= form.select :status,
            Tweet::status_enum_array(),
            { selected: val },
            include_blank: "選択して下さい"
        %>
        <br />
        <input type="button" value="<%= Tweet::StatusEnum::TO_BE_OBTAIN %>" onclick="set_status('<%= Tweet::StatusEnum::TO_BE_OBTAIN %>');" class="btn" />
        <input type="button" value="<%= Tweet::StatusEnum::UNACCESSIBLE %>" onclick="set_status('<%= Tweet::StatusEnum::UNACCESSIBLE %>');" class="btn" />
    </div>

    <div>
        <%= form.label :rating, style: "display: block" %>
        <%= form.number_field :rating %>
    </div>

    <div>
        <%= form.label :num, style: "display: block" %>
        <%= form.number_field :num %>
    </div>
    
    <div>
        <%= form.label :remarks, style: "display: block" %>
        <%= form.text_field :remarks %>
        ←
        <input type="button" value="ファイル名取り出し" onclick="get_filename();" />
        <input type=”text” id="url_filepath" value="" />
    </div>

    <div>
        <%= form.submit("更新", class: 'submit-btn') %>
    </div>

    <% if tweet.screen_name.presence and tweet.screen_name != Twt::TWT_USER_I %>
        <% tweet_ids = Twt::get_twt_tweet_ids_from_txts(tweet.screen_name) %>
        <% ids = Tweet::get_unregistered_tweet_ids(tweet_ids) %>
        <% if ids.size > 0 %>
            <h2>url txt</h2>
            <% ids.each do |x| %>
                <% url = Twt::twt_tweet_url(tweet.screen_name, x) %>
                <%= link_to_ex(url, url) %>
                [<%= Twt::timestamp_str(x) %>]

                <% twt_pic_path_list = Twt::get_pic_filelist(tweet.screen_name) %>
                <% paths = Twt::search_tweet(twt_pic_path_list, x) %>
                <% if paths.size > 0 %>
                    ファイルあり
                <% else %>
                    <% url2 = Twt::twt_tweet_url_dev(x) %>
                    <%= link_to_ex(url2, url2) %>
                <% end %>
                <br>
            <% end %>
        <% end %>
    <% end %>
<% end %>

<script>
    function select_text(elem_id) {
        const text_field = document.getElementById(elem_id);
        text_field.select();
        //document.execCommand("copy");
    }

    document.addEventListener("visibilitychange", function() {
        if (document.visibilityState === "visible")
        {
            const s_elem_id = "tweet_" + "screen_name";
            const s_text_field = document.getElementById(s_elem_id);
            if (s_text_field.value == "") {
                select_text(s_elem_id);
            } else {
                const f_elem_id = "url_filepath";
                select_text(f_elem_id);
            }
        }
    });

    function set_status(statusi)
    {
        const status_e = document.getElementById('tweet_status');
        selectOptionByText(status_e, statusi);
    }

    function get_filename() {
        let text_box = document.getElementById("url_filepath");
        let text = text_box.value;

        let filename = "";
        const regex = /.*\/(.+)$/;
        //console.log(regex);

        const match = text.match(regex);
        //if (regex.test(text)) {
        if (match) {
            filename = match[1];
        } else {
            filename = text;
        }
        
        const remarks_e = document.getElementById('tweet_remarks');
        remarks_e.value = filename;

        set_status("<%= Tweet::StatusEnum::SAVED %>");
    }

    /**
     * セレクトボックスの項目名（テキスト）を指定して選択状態にする
     * @param {HTMLSelectElement} selectObj - セレクトボックスのDOMオブジェクト
     * @param {string} targetText - 選択したい項目の表示文字列
     */
    function selectOptionByText(selectObj, targetText) {
        // セレクトボックス内の全てのoption要素をループ
        for (let i = 0; i < selectObj.options.length; i++) {
            // 項目のテキストが引数と一致するか確認
            if (selectObj.options[i].text === targetText) {
                // 一致した項目のインデックスを選択状態にする
                selectObj.selectedIndex = i;
                
                // 値の変更をプログラムから行った場合、changeイベントは自動で発火しないため
                // 必要に応じて手動でディスパッチすることも可能です
                // selectObj.dispatchEvent(new Event('change'));
                
                return true; // 見つかったので終了
            }
        }
        console.warn("指定された項目名が見つかりませんでした: " + targetText);
        return false;
    }
</script>
