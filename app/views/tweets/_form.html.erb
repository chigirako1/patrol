<%= form_with(model: tweet) do |form| %>
  <% if tweet.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(tweet.errors.count, "error") %> prohibited this tweet from being saved:</h2>

      <ul>
        <% tweet.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <% if tweet.tweet_id.presence %>
      <% tweet_id_val = tweet.tweet_id %>
    <% elsif params[:tweet_id].presence %>
      <% tweet_id_val = params[:tweet_id] %>
    <% else %>
      <% tweet_id_val = "" %>
    <% end %>
    <%= form.label :tweet_id, style: "display: block" %>
    <%= form.number_field :tweet_id, value: tweet_id_val %>

    <%= link_to_ex("▶x(#{tweet_id_val})", Twt::twt_tweet_url_i(tweet_id_val)) %>
  </div>

  <div>
    <%= form.label :screen_name, style: "display: block" %>
    <%= form.text_field :screen_name, autofocus: true %>
    <%= link_to_ex("▶@" + tweet.screen_name, Twt::twt_user_media_url(tweet.screen_name)) if tweet.screen_name.presence %>

    <%= twitter_info_tag_ex(tweet.screen_name, true) %>
  </div>

  <div>
    <% val = get_val(tweet.status, :status) %>
    <%= form.label :status, style: "display: block" %>
    <%= form.select :status,
      Tweet::status_enum_array(),
      { selected: val },
      include_blank: "選択して下さい"
    %>
  </div>

  <div>
    <%= form.label :rating, style: "display: block" %>
    <%= form.number_field :rating %>
  </div>

  <div>
    <%= form.label :num, style: "display: block" %>
    <%= form.number_field :num %>
  </div>
  
  <div>
    <%= form.label :remarks, style: "display: block" %>
    <%= form.text_field :remarks %>
  </div>

  <div>
    <%= form.submit %>
  </div>

  <% if tweet.screen_name.presence and tweet.screen_name != Twt::TWT_USER_I %>
    <% tweet_ids = Twt::get_twt_tweet_ids_from_txts(tweet.screen_name) %>
    <% ids = Tweet::get_unregistered_tweet_ids(tweet_ids) %>
    <% if ids.size > 0 %>
      <h2>url txt</h2>
    <% end %>
    <% ids.each do |x| %>
        <% url = Twt::twt_tweet_url(tweet.screen_name, x) %>
        <%= link_to_ex(url, url) %>
        [<%= Twt::timestamp_str(x) %>]

        <% twt_pic_path_list = Twt::get_pic_filelist(tweet.screen_name) %>
        <% paths = Twt::search_tweet(twt_pic_path_list, x) %>
        <% if paths.size > 0 %>
            ファイルあり
        <% else %>
            <% url2 = Twt::twt_tweet_url_dev(x) %>
            <%= link_to_ex(url2, url2) %>
        <% end %>
        <br>
    <% end %>
  <% end %>
<% end %>

<script>
    function select_text(elem_id) {
        let text_field = document.getElementById(elem_id);
        text_field.select();
        //document.execCommand("copy");
    }

    document.addEventListener("visibilitychange", function() {
      if (document.visibilityState === "visible")
      {
          select_text("tweet_" + "screen_name");
      }
    });
</script>
