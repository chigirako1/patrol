<% provide(:title, "stats") %>

<h1>stats</h1>

<% @stats.each do |key, val| %>
    <h2><%= key %></h2>
    <% sum = val.values.inject(:+) %>
    <table border="1" rules="all">
        <tr>
            <th>key</th>
            <th>val</th>
            <th>%</th>
            <th></th>
        </tr>
        <% val.each do |k, v| %>
            <tr>
                <td>
                    <%#= %!"#{k}"! %>
                    <% if key.include?("pxv") %>
                        <% if key =~ /.*:(.*)/ %>
                            <% col = $1 %>
                            <% if col == "status" %>
                                <% url = artists_path(page_title: "xxx", status: k, ai: true) %>
                            <% elsif col == Twitter::RESTRICT::R18 %>
                                <% url = artists_path(page_title: "xxx", r18: k, ai: true) %>
                            <% end %>
                        <% end %>
                    <% elsif key.include?("twt") %>

                        <% url = twitters_path(page_title: "xxx", mode: TwittersController::ModeEnum::STATS, rating: k, rating_lt: k, target: "AI") %>
                    <% else %>
                    <% end %>
                    <%= link_to_ex("#{k}", url) %>
                </td>
                <td align="right">
                    <%= %!#{v}! %>
                </td>

                <% percent = (v.to_f / sum * 100).round(1) %>
                
                <td align="right">
                    <%= %!#{percent}! %>
                </td>
                <td>
                    <%= "*" * ((percent / 2) + 1) %>
                </td>
            </tr>
        <% end %>
        <tr>
            <td>
                計
            </td>
            <td align="right">
                <%= %!#{sum}! %>
            </td>
            <td>
            </td>
    </table>
<% end %>

<h1>xxx</h1>

<h2>huge</h2>
<% @sp_ids.each do |screen_name| %>
    <%= screen_name %><br />
<% end %>

<h2>vid id</h2>
<% @vid_ids.each do |screen_name| %>
    <%= screen_name %><br />
<% end %>

<h2>vid url</h2>
<% @vid_urls.each do |line| %>
    <%= line %><br />
<% end %>

<h2>@mov_url_list</h2>
<% @mov_url_list.each do |x| %>
    <%= x %><br />
<% end %>

<% @mov_url_hash.each do |k,v| %>
    <hr />
    <%= twitter_info_tag_ex(k) unless k == Twt::TWT_USER_I %>
    <hr size="5" color="yellow" />
    <% v.sort_by {|x| x.tweet_id}.each do |x| %>
        <% url = Twt::twt_tweet_url(x.screen_name, x.tweet_id) %>
        <%= link_to_ex("#{x.screen_name} #{x.tweet_id} 0 ", url) %>
        (<%= smart_date Twt::get_timestamp(x.tweet_id) %>)
        <br />
    <% end %>
<% end %>
