<% title = %!@#{@twtid}:画像一覧! %>
<% provide(:title, title) %>

<h3 id="twt_pic_list">Twt::twt_path_str(<%= link_to_ex "@#{@twtid}", Twt::twt_user_media_url(@twtid) %>)</h3>

<% twt_acnt = Twitter.find_by_twtid_ignore_case(@twtid) %>
<% if twt_acnt == nil %>
    <%= link_to "New Twt", new_twitter_path(twtid: @twtid, status: "TWT巡回") %>
    <br />
<% else %>
    twt:<%= twt_acnt.twtname %>[<%= link_to "show", twt_acnt, target: :_blank, rel: "noopener noreferrer" %>]
    <%#= twt_acnt.last_access_datetime_disp %>
    <%= twt_acnt.status %>,<%= twt_acnt.drawing_method %>
    <br />

    <% pxv_acnt = Artist.find_by(pxvid: twt_acnt.pxvid) %>
    <% if pxv_acnt != nil %>
        pxv:<%= pxv_acnt.pxvname %> [<%= link_to "show", pxv_acnt, target: :_blank, rel: "noopener noreferrer" %>]
        <br />
    <% end %>
<% end %>

<% pxv_artist = Artist.find_by_twtid_ignore_case(@twtid) %>
<% if pxv_artist %>
    pxv:<%= pxv_artist.pxvname %> [<%= link_to "show", pxv_artist, target: :_blank, rel: "noopener noreferrer" %>]
        <%= pxv_artist.get_datetime_string(pxv_artist.last_ul_datetime) %>
        <%= pxv_artist.status %>
    <br />
<% else %>
    pxvなし
<% end %>
<hr />

<% twt_img_list = TwtImageList::new(@twt_pic_path_list, true) %>

<% freq = twt_img_list.calc_freq %>
更新頻度：<%= freq %>枚/<%= Twt::CALC_FREQ_UNIT %>日
<% if twt_acnt != nil and twt_acnt.update_frequency != nil %>
    <% current_val_freq = twt_acnt.update_frequency %>
    <%= %!(現在値：#{current_val_freq})! %>
    <% if (freq - current_val_freq).abs >= 50 %>
        現在値との差が大きい
    <% end %>
<% end %>
<br />

<% if params[:picn] == "" %>
    <% show_pic_num = 15 %>
<% elsif params[:picn] == "all" %>
    <% show_pic_num = twt_img_list.list.size %>
<% elsif params[:picn] =~ /(\d+)/ %>
    <% show_pic_num = $1.to_i %>
<% else %>
    <% show_pic_num = 15 %>
<% end %>

<% if params[:sdate] %>
    <% sdate = Util::parse_date_str(params[:sdate]) %>
    <% show_pic_num = twt_img_list.list.size %>
<% end %>

<% if params[:nl] and params[:nl] == "true" %>
    <% nl = true %>
<% else %>
    <% nl = false %>
<% end %>

<h4>twt_img_list(<%= twt_img_list.list.size %>)</h4>
<% twt_img_list.list.first(show_pic_num).each.with_index(1) do |elem, idx| %>
    <% if nl and elem.first_pic? %>
        <hr />
    <% end %>
    <% path = elem.file_path %>
    <%= idx %>.
    <%= image_link(path, get_image_class(elem.first_pic?)) %>

    <% if sdate %>
        <% postdate = elem.datetime %>
        <% if postdate.to_date == sdate %>
            <% smart_date sdate %>
        <% end %>

        <% if postdate.to_date < sdate %>
            <% break %>
        <% end %>
    <% end %>
<% end %>
<br />

<% twt_img_list.list.first(show_pic_num).each.with_index(1) do |elem, idx| %>
    <%= idx %>:<%= Twt::twt_path_str elem.file_path %>
    <% url = Twt::twt_tweet_url(@twtid, elem.tweet_id) %>
    <% if false %>
        [<%= link_to_ex("▶", url) %>]
    <% end %>
    <br />

    <% if sdate %>
        <% postdate = elem.datetime %>
        <% if postdate.to_date < sdate %>
            <% break %>
        <% end %>
    <% end %>
<% end %>
<br />

<% if twt_img_list.list.presence %>
    <b><%= Twt::twt_img_search_str(@twtid, twt_img_list.list.last.datetime, twt_img_list.list.first.datetime) %></b>
    <br />
<% end %>

<%= link_to("...全て表示", artist_twt_path(@twtid, picn: 33, nl: true)) %>
<br />


<!-- ########################## --
 ! SP
 !-- ########################## -->
<% filelist = Twt::get_sp_pic_filelist_by_twtid(@twtid) %>
<% if filelist and filelist.size > 0 %>
    <h4>SP(<%= File.dirname filelist.first %>)[<%= filelist.size %>ファイル]</h4>
    <% filelist.reverse.first(show_pic_num).each.with_index(1) do |fpath, idx| %>
        <%= idx %>.<%= link_to_ex(image_tag(fpath, class: "fixed-height-img"), fpath) %>
    <% end %>
    <br />
<% else %>
    spなし<br />
<% end %>

<!-- ########################## --
 ! SP2
 !-- ########################## -->
<% filelist2 = Twt::get_sp_pic_filelist2_by_twtid(@twtid) %>
<% if filelist2.size > 0 %>
    <h4>SP2(<%= File.dirname filelist2.first %>)[<%= filelist2.size %>ファイル]</h4>
    <% filelist2.reverse.first(show_pic_num).each.with_index(1) do |fpath, idx| %>
        <%= idx %>.<%= link_to_ex(image_tag(fpath, class: "fixed-height-img"), fpath) %>
    <% end %>
<% else %>
    sp2なし<br />
<% end %>

<!-- ########################## -->
<h2>url txt</h2>
<!-- ########################## -->
<% tweet_ids = Twt::get_twt_tweet_ids_from_txts(@twtid) %>
<% if tweet_ids.size == 0 %>
    なし
<% end %>
<% tweet_ids.each do |x| %>
    <% url = Twt::twt_tweet_url(@twtid, x) %>
    <%= link_to_ex(url, url) %>
    [<%= Twt::timestamp_str(x) %>]

    <% paths = Twt::search_tweet(@twt_pic_path_list, x) %>
    <% if paths.size > 0 %>
        ファイルあり
    <% else %>
        <% url2 = Twt::twt_tweet_url_dev(x) %>
        <%= link_to_ex(url2, url2) %>
    <% end %>
    <br>
<% end %>

<hr />
<%= form_with url: artists_path, local: true, method: :get do |f| %>
    <%= f.label :file, style: "display: block" %>
    <%= f.select :file, 
      options_for_select(
        [
          ['検索'],
        ],
        selected: params[:file] 
      ) %>
    <br />

    検索：<%= f.text_field :search_word %>
    <%= f.select :match_method, options_for_select([["(自動判断)","auto"], ["を含む","partial_match"], ["完全一致","perfect_match"], ["から始まる","begin_match"],  ["で終わる","end_match"]]) %>
    <%= f.select :target_col, options_for_select([['(自動判断)'], ['pxvname'], ['pxvid']]) %>
    <br />
    <%= f.submit "検索", name: nil %>
<% end %>
